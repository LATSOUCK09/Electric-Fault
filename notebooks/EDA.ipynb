{
 "cells": [
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "# 📊 Exploratory Data Analysis (EDA)\n",
    "## Maintenance Data - Electric Fault Project\n",
    "\n",
    "**Objectif:** Comprendre la structure des données, identifier patterns et anomalies"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "import pandas as pd\n",
    "import numpy as np\n",
    "import matplotlib.pyplot as plt\n",
    "import seaborn as sns\n",
    "from datetime import datetime\n",
    "import warnings\n",
    "warnings.filterwarnings('ignore')\n",
    "\n",
    "# Configuration matplotlib\n",
    "plt.style.use('seaborn-v0_8-darkgrid')\n",
    "sns.set_palette(\"husl\")\n",
    "plt.rcParams['figure.figsize'] = (14, 6)\n",
    "plt.rcParams['font.size'] = 10\n",
    "\n",
    "print(\"✅ Libraries loaded successfully\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 1. CHARGEMENT DES DONNÉES"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Charger les données\n",
    "df = pd.read_csv('data/processed/cleaned_data.csv')\n",
    "\n",
    "print(f\"📊 DATASET OVERVIEW\")\n",
    "print(f\"Dimensions: {df.shape[0]} lignes × {df.shape[1]} colonnes\")\n",
    "print(f\"\\nColonnes:\")\n",
    "print(df.columns.tolist())"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Afficher aperçu des données\n",
    "print(\"\\n🔍 FIRST 5 ROWS:\")\n",
    "df.head()"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Info du dataset\n",
    "print(\"\\n📋 DATA TYPES & MISSING VALUES:\")\n",
    "info_df = pd.DataFrame({\n",
    "    'Column': df.columns,\n",
    "    'Type': df.dtypes,\n",
    "    'Non-Null': df.count(),\n",
    "    'Null': df.isna().sum(),\n",
    "    'Null %': (df.isna().sum() / len(df) * 100).round(2)\n",
    "})\n",
    "info_df"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 2. ANALYSE DES COÛTS"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Statistiques des coûts\n",
    "cost_columns = ['coutMaintenance', 'CoutMainDoeuvre', 'CoutMateriel', 'CoutService', 'CoutMoyen']\n",
    "\n",
    "print(\"💰 COST STATISTICS:\")\n",
    "cost_stats = df[cost_columns].describe().T\n",
    "cost_stats"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Distribution des coûts\n",
    "fig, axes = plt.subplots(2, 2, figsize=(15, 10))\n",
    "fig.suptitle('📊 Cost Distribution Analysis', fontsize=16, fontweight='bold')\n",
    "\n",
    "# coutMaintenance\n",
    "axes[0, 0].hist(df['coutMaintenance'], bins=50, edgecolor='black', alpha=0.7, color='steelblue')\n",
    "axes[0, 0].set_title('coutMaintenance Distribution')\n",
    "axes[0, 0].set_xlabel('Cost')\n",
    "axes[0, 0].set_ylabel('Frequency')\n",
    "\n",
    "# CoutMainDoeuvre\n",
    "axes[0, 1].hist(df['CoutMainDoeuvre'], bins=50, edgecolor='black', alpha=0.7, color='coral')\n",
    "axes[0, 1].set_title('CoutMainDoeuvre Distribution')\n",
    "axes[0, 1].set_xlabel('Cost')\n",
    "axes[0, 1].set_ylabel('Frequency')\n",
    "\n",
    "# CoutMateriel\n",
    "axes[1, 0].hist(df['CoutMateriel'], bins=50, edgecolor='black', alpha=0.7, color='lightgreen')\n",
    "axes[1, 0].set_title('CoutMateriel Distribution')\n",
    "axes[1, 0].set_xlabel('Cost')\n",
    "axes[1, 0].set_ylabel('Frequency')\n",
    "\n",
    "# CoutService\n",
    "axes[1, 1].hist(df['CoutService'], bins=50, edgecolor='black', alpha=0.7, color='orange')\n",
    "axes[1, 1].set_title('CoutService Distribution')\n",
    "axes[1, 1].set_xlabel('Cost')\n",
    "axes[1, 1].set_ylabel('Frequency')\n",
    "\n",
    "plt.tight_layout()\n",
    "plt.savefig('outputs/dashboards/cost_distribution.png', dpi=300, bbox_inches='tight')\n",
    "plt.show()\n",
    "\n",
    "print(\"✅ Cost distribution plot saved\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Box plots pour outliers\n",
    "fig, ax = plt.subplots(figsize=(14, 6))\n",
    "\n",
    "cost_data = [df['coutMaintenance'], df['CoutMainDoeuvre'], \n",
    "             df['CoutMateriel'], df['CoutService']]\n",
    "labels = ['coutMaintenance', 'CoutMainDoeuvre', 'CoutMateriel', 'CoutService']\n",
    "\n",
    "bp = ax.boxplot(cost_data, labels=labels, patch_artist=True)\n",
    "\n",
    "for patch in bp['boxes']:\n",
    "    patch.set_facecolor('lightblue')\n",
    "\n",
    "ax.set_title('📦 Cost Outliers Detection', fontsize=14, fontweight='bold')\n",
    "ax.set_ylabel('Cost Amount')\n",
    "plt.xticks(rotation=15)\n",
    "plt.tight_layout()\n",
    "plt.savefig('outputs/dashboards/cost_outliers_boxplot.png', dpi=300, bbox_inches='tight')\n",
    "plt.show()\n",
    "\n",
    "print(\"✅ Outliers boxplot saved\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 3. ANALYSE PAR ZONE & FAMILLE D'ÉQUIPEMENT"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Coûts par Zone\n",
    "print(\"\\n🗺️  COSTS BY ZONE:\")\n",
    "costs_by_zone = df.groupby('zone').agg({\n",
    "    'coutMaintenance': ['sum', 'mean', 'count'],\n",
    "    'CoutMainDoeuvre': 'mean',\n",
    "    'CoutMateriel': 'mean'\n",
    "}).round(2)\n",
    "costs_by_zone.columns = ['Total Cost', 'Avg Cost', 'Count', 'Avg Labour', 'Avg Material']\n",
    "costs_by_zone.sort_values('Total Cost', ascending=False)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Coûts par Famille d'Équipement\n",
    "print(\"\\n🏭 COSTS BY EQUIPMENT FAMILY:\")\n",
    "costs_by_family = df.groupby('familleEquipement').agg({\n",
    "    'coutMaintenance': ['sum', 'mean', 'count'],\n",
    "    'CoutMainDoeuvre': 'mean',\n",
    "    'CoutMateriel': 'mean'\n",
    "}).round(2)\n",
    "costs_by_family.columns = ['Total Cost', 'Avg Cost', 'Count', 'Avg Labour', 'Avg Material']\n",
    "costs_by_family.sort_values('Total Cost', ascending=False)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Visualisation des coûts par Zone\n",
    "fig, axes = plt.subplots(1, 2, figsize=(16, 6))\n",
    "fig.suptitle('💰 Cost Analysis by Zone & Equipment Family', fontsize=14, fontweight='bold')\n",
    "\n",
    "# Par Zone\n",
    "zone_costs = df.groupby('zone')['coutMaintenance'].sum().sort_values(ascending=False)\n",
    "axes[0].barh(zone_costs.index, zone_costs.values, color='steelblue')\n",
    "axes[0].set_xlabel('Total Cost')\n",
    "axes[0].set_title('Total Maintenance Cost by Zone')\n",
    "\n",
    "# Par Famille\n",
    "family_costs = df.groupby('familleEquipement')['coutMaintenance'].sum().sort_values(ascending=False)\n",
    "axes[1].barh(family_costs.index, family_costs.values, color='coral')\n",
    "axes[1].set_xlabel('Total Cost')\n",
    "axes[1].set_title('Total Maintenance Cost by Equipment Family')\n",
    "\n",
    "plt.tight_layout()\n",
    "plt.savefig('outputs/dashboards/cost_by_zone_family.png', dpi=300, bbox_inches='tight')\n",
    "plt.show()\n",
    "\n",
    "print(\"✅ Cost analysis plot saved\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 4. ANALYSE TEMPORELLE"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Conversion des dates\n",
    "date_cols = ['dateCreation', 'dateDebutPrevue', 'dateFinPrevue', 'DatePlanifiee']\n",
    "for col in date_cols:\n",
    "    if col in df.columns:\n",
    "        df[col] = pd.to_datetime(df[col], errors='coerce')\n",
    "\n",
    "print(\"\\n📅 DATE RANGE:\")\n",
    "print(f\"Earliest date: {df['dateCreation'].min()}\")\n",
    "print(f\"Latest date: {df['dateCreation'].max()}\")\n",
    "print(f\"Days span: {(df['dateCreation'].max() - df['dateCreation'].min()).days} days\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Interventions par mois\n",
    "df['month'] = df['dateCreation'].dt.to_period('M')\n",
    "interventions_by_month = df.groupby('month').size()\n",
    "\n",
    "fig, ax = plt.subplots(figsize=(14, 6))\n",
    "interventions_by_month.plot(kind='bar', ax=ax, color='steelblue', edgecolor='black')\n",
    "ax.set_title('📈 Interventions by Month', fontsize=14, fontweight='bold')\n",
    "ax.set_xlabel('Month')\n",
    "ax.set_ylabel('Number of Interventions')\n",
    "plt.xticks(rotation=45)\n",
    "plt.grid(axis='y', alpha=0.3)\n",
    "plt.tight_layout()\n",
    "plt.savefig('outputs/dashboards/interventions_by_month.png', dpi=300, bbox_inches='tight')\n",
    "plt.show()\n",
    "\n",
    "print(\"✅ Temporal analysis plot saved\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 5. ANALYSE DES ÉQUIPEMENTS"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Top équipements par coût\n",
    "print(\"\\n🏆 TOP 10 MOST EXPENSIVE EQUIPMENT:\")\n",
    "top_costly = df.groupby('codeEquipement').agg({\n",
    "    'coutMaintenance': 'sum',\n",
    "    'codeOT': 'count',\n",
    "    'zone': 'first',\n",
    "    'familleEquipement': 'first'\n",
    "}).sort_values('coutMaintenance', ascending=False).head(10)\n",
    "top_costly.columns = ['Total Cost', 'Interventions', 'Zone', 'Family']\n",
    "top_costly"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Top équipements par fréquence d'intervention\n",
    "print(\"\\n🔧 TOP 10 MOST MAINTAINED EQUIPMENT:\")\n",
    "top_frequent = df.groupby('codeEquipement').agg({\n",
    "    'codeOT': 'count',\n",
    "    'coutMaintenance': 'sum',\n",
    "    'zone': 'first',\n",
    "    'familleEquipement': 'first'\n",
    "}).sort_values('codeOT', ascending=False).head(10)\n",
    "top_frequent.columns = ['Interventions', 'Total Cost', 'Zone', 'Family']\n",
    "top_frequent"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 6. ANALYSE DES TYPES D'INTERVENTION"
   ]
  },
  {
   "cell_type": {"text": [
    "text/plain": [],
    "metadata": {}
   }},
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Distribution des interventions\n",
    "print(\"\\n📋 INTERVENTION TYPES DISTRIBUTION:\")\n",
    "intervention_stats = df.groupby('typeIntervention').agg({\n",
    "    'codeOT': 'count',\n",
    "    'coutMaintenance': ['sum', 'mean']\n",
    "}).sort_values(('codeOT', 'count'), ascending=False)\n",
    "intervention_stats.columns = ['Count', 'Total Cost', 'Avg Cost']\n",
    "intervention_stats"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Visualisation\n",
    "fig, axes = plt.subplots(1, 2, figsize=(15, 6))\n",
    "fig.suptitle('📊 Intervention Analysis', fontsize=14, fontweight='bold')\n",
    "\n",
    "# Pie chart - distribution\n",
    "intervention_count = df['typeIntervention'].value_counts()\n",
    "axes[0].pie(intervention_count.values, labels=intervention_count.index, autopct='%1.1f%%')\n",
    "axes[0].set_title('Distribution by Type')\n",
    "\n",
    "# Bar chart - coûts\n",
    "intervention_cost = df.groupby('typeIntervention')['coutMaintenance'].sum().sort_values(ascending=False)\n",
    "axes[1].bar(intervention_cost.index, intervention_cost.values, color='coral', edgecolor='black')\n",
    "axes[1].set_title('Total Cost by Type')\n",
    "axes[1].set_ylabel('Cost')\n",
    "plt.setp(axes[1].xaxis.get_majorticklabels(), rotation=45, ha='right')\n",
    "\n",
    "plt.tight_layout()\n",
    "plt.savefig('outputs/dashboards/intervention_analysis.png', dpi=300, bbox_inches='tight')\n",
    "plt.show()\n",
    "\n",
    "print(\"✅ Intervention analysis plot saved\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 7. DÉTECTION D'ANOMALIES"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Détection d'anomalies coûts (Z-score)\n",
    "from scipy import stats\n",
    "\n",
    "df['cost_zscore'] = np.abs(stats.zscore(df['coutMaintenance'].fillna(0)))\n",
    "anomalies = df[df['cost_zscore'] > 3]\n",
    "\n",
    "print(f\"\\n🚨 COST ANOMALIES DETECTED: {len(anomalies)}\")\n",
    "print(f\"Percentage: {len(anomalies)/len(df)*100:.2f}%\")\n",
    "print(f\"\\nTop anomalies:\")\n",
    "anomalies[['codeOT', 'codeEquipement', 'coutMaintenance', 'zone', 'familleEquipement']].head(10)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Isolation Forest pour anomalies multivariées\n",
    "from sklearn.ensemble import IsolationForest\n",
    "\n",
    "# Préparer les features\n",
    "X = df[['coutMaintenance', 'CoutMainDoeuvre', 'CoutMateriel', 'CoutService']].fillna(0)\n",
    "\n",
    "# Appliquer Isolation Forest\n",
    "iso_forest = IsolationForest(contamination=0.05, random_state=42)\n",
    "anomaly_labels = iso_forest.fit_predict(X)\n",
    "df['anomaly_if'] = anomaly_labels\n",
    "\n",
    "anomalies_if = df[df['anomaly_if'] == -1]\n",
    "print(f\"\\n🔴 MULTIVARIATE ANOMALIES: {len(anomalies_if)}\")\n",
    "print(f\"\\nTop anomalies (Isolation Forest):\")\n",
    "anomalies_if[['codeOT', 'codeEquipement', 'coutMaintenance', 'CoutMainDoeuvre', 'CoutMateriel']].head(10)"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 8. RÉSUMÉ & CONCLUSIONS"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Rapport final\n",
    "print(\"\\n\" + \"=\"*70)\n",
    "print(\"📊 EDA SUMMARY REPORT\")\n",
    "print(\"=\"*70)\n",
    "\n",
    "print(f\"\\n📈 DATASET STATISTICS:\")\n",
    "print(f\"  Total Records: {len(df):,}\")\n",
    "print(f\"  Total Unique Equipments: {df['codeEquipement'].nunique()}\")\n",
    "print(f\"  Total Unique OT: {df['codeOT'].nunique()}\")\n",
    "print(f\"  Date Range: {df['dateCreation'].min().date()} to {df['dateCreation'].max().date()}\")\n",
    "\n",
    "print(f\"\\n💰 COST INSIGHTS:\")\n",
    "print(f\"  Total Maintenance Cost: {df['coutMaintenance'].sum():,.2f}\")\n",
    "print(f\"  Average Maintenance Cost: {df['coutMaintenance'].mean():,.2f}\")\n",
    "print(f\"  Max Maintenance Cost: {df['coutMaintenance'].max():,.2f}\")\n",
    "print(f\"  Cost Anomalies (Z>3): {len(anomalies)}\")\n",
    "print(f\"  Cost Anomalies (IF): {len(anomalies_if)}\")\n",
    "\n",
    "print(f\"\\n🏆 TOP ZONES:\")\n",
    "top_zones = df.groupby('zone')['coutMaintenance'].sum().sort_values(ascending=False).head(3)\n",
    "for zone, cost in top_zones.items():\n",
    "    print(f\"  {zone}: {cost:,.2f}\")\n",
    "\n",
    "print(f\"\\n🏭 TOP FAMILIES:\")\n",
    "top_families = df.groupby('familleEquipement')['coutMaintenance'].sum().sort_values(ascending=False).head(3)\n",
    "for family, cost in top_families.items():\n",
    "    print(f\"  {family}: {cost:,.2f}\")\n",
    "\n",
    "print(f\"\\n🔧 INTERVENTION TYPES:\")\n",
    "for itype, count in df['typeIntervention'].value_counts().items():\n",
    "    print(f\"  {itype}: {count} ({count/len(df)*100:.1f}%)\")\n",
    "\n",
    "print(\"\\n\" + \"=\"*70)"
   ]
  }
 ],
